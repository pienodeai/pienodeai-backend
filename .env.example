# Server
PORT=3000
NODE_ENV=development

# MongoDB (required) - use your Atlas connection string
# Example for cluster pienodeai.6u5ca8r.mongodb.net:
MONGODB_URI=mongodb+srv://<user>:<password>@pienodeai.6u5ca8r.mongodb.net/?retryWrites=true&w=majority

# CORS - comma-separated origins (e.g. http://localhost:3000,https://pinodeai.com)
CORS_ORIGINS=http://localhost:3000

# Optional: Email (for contact/newsletter - integrate Resend/SendGrid later)
# RESEND_API_KEY=
# CONTACT_EMAIL=hello@pinodeai.com
