# Server
PORT=3000
NODE_ENV=development

# MongoDB (required)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# CORS - comma-separated origins (e.g. http://localhost:3000,https://pinodeai.com)
CORS_ORIGINS=http://localhost:3000

# Optional: Email (for contact/newsletter - integrate Resend/SendGrid later)
# RESEND_API_KEY=
# CONTACT_EMAIL=hello@pinodeai.com
